# Copy to .env.local for local development (never commit .env.local)

# Super Admin (frontend)
VITE_SUPER_ADMIN_EMAIL=superadmin@workforce.pro
VITE_SUPER_ADMIN_PASSWORD=your-secure-password-here

# Razorpay — backend only (add same vars in Vercel dashboard)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# Local payment API port (optional, default 3001)
API_PORT=3001
